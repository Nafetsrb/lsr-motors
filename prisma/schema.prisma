generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MECHANIC
  CLIENT
}

enum InterventionStatus {
  DEPOSITED
  DIAGNOSED
  IN_PROGRESS
  COMPLETED
  READY
  DELIVERED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  phone         String?
  role          Role           @default(CLIENT)
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  motorcycles   Motorcycle[]
  interventions Intervention[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Motorcycle {
  id            String         @id @default(cuid())
  brand         String
  model         String
  year          Int?
  licensePlate  String?
  vin           String?
  color         String?
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id])
  interventions Intervention[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Intervention {
  id            String             @id @default(cuid())
  motorcycleId  String
  motorcycle    Motorcycle         @relation(fields: [motorcycleId], references: [id])
  clientId      String
  client        User               @relation(fields: [clientId], references: [id])
  status        InterventionStatus @default(DEPOSITED)
  mileage       Int?
  description   String?            @db.Text
  estimatedCost Float?
  totalCost     Float?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  tasks         Task[]
  medias        Media[]
  notes         Note[]
}

model Task {
  id             String       @id @default(cuid())
  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  title          String
  description    String?      @db.Text
  status         TaskStatus   @default(PENDING)
  laborCost      Float?
  isVisible      Boolean      @default(true)
  parts          Part[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Part {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int      @default(1)
  unitCost  Float?
  notes     String?
  createdAt DateTime @default(now())
}

model Media {
  id             String       @id @default(cuid())
  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  type           String
  url            String
  label          String?
  isVisible      Boolean      @default(true)
  createdAt      DateTime     @default(now())
}

model Note {
  id             String       @id @default(cuid())
  interventionId String
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  isVisible      Boolean      @default(false)
  createdAt      DateTime     @default(now())
}
